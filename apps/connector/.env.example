# Preferred: use shared config generated by setup wizard
GAMEOPS_CONFIG_PATH=./config/gameops.config.json
# Required only when multiple enabled servers exist in config
CONNECTOR_SERVER_ID=valheim-local-1

# Optional overrides (normally taken from shared config)
GAME_KEY=valheim
CONNECTOR_MODE=file
VALHEIM_LOG_FILE=./samples/valheim.sample.log
PALWORLD_LOG_FILE=./samples/palworld.sample.log
PALWORLD_REST_HOST=127.0.0.1
PALWORLD_REST_PORT=8212
PALWORLD_REST_USERNAME=admin
PALWORLD_REST_PASSWORD=replace-with-admin-password
PALWORLD_REST_PATH=/v1/api
VALHEIM_JOURNAL_SERVICE=run-valheim.service
API_BASE_URL=http://localhost:3001
POLL_INTERVAL_MS=2000
KNOWN_PLAYER_STORE_PATH=../known-players.json
