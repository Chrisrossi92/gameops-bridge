[Unit]
Description=GameOps Bridge Connector (palworld-fantasy-1)
After=network.target

[Service]
Type=simple
WorkingDirectory=/Users/christopherrossi/Desktop/Projects/gameops-bridge
Environment=NODE_ENV=production
Environment=GAMEOPS_CONFIG_PATH=/tmp/gameops.bootstrap.sample.json
Environment=CONNECTOR_SERVER_ID=palworld-fantasy-1
ExecStart=/usr/bin/env npm --workspace apps/connector run dev
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
